{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "descriptionRu": {
      "type": "string"
    },
    "technologies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "githubUrl": {
      "type": "string",
      "format": "uri"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "order": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "technologies",
    "order"
  ]
}