---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/hero/HeroSection.astro';
import Timeline from '../components/experience/Timeline.astro';
import SkillGrid from '../components/skills/SkillGrid.astro';
import ProjectCard from '../components/projects/ProjectCard.astro';
import social from '../data/social.json';
---

<Base lang="en" title="Mark Gurianov — Team Lead">
  <main>
    <HeroSection lang="en" />
    <Timeline lang="en" />
    <SkillGrid lang="en" />
    <ProjectCard lang="en" />

    <footer class="footer">
      <div class="container">
        <p class="footer__text">{social.nameEn} · {new Date().getFullYear()}</p>
      </div>
    </footer>
  </main>
</Base>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-8);
  }
  .footer__text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
