---
import { getCollection } from 'astro:content';
import social from '../data/social.json';
import skills from '../data/skills.json';

const experience = (await getCollection('experience')).sort((a, b) => a.data.order - b.data.order);
const projects   = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Resume — {social.nameEn}</title>
    <style>
      /* ── Reset ── */
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* ── Tokens ── */
      :root {
        --accent:  #5b5ef4;
        --text:    #111827;
        --muted:   #6b7280;
        --border:  #e5e7eb;
        --bg:      #ffffff;
        --surface: #f9fafb;
        --sans:    'Inter', system-ui, sans-serif;
        --mono:    'JetBrains Mono', 'Fira Code', monospace;
      }

      /* ── Base ── */
      body {
        font-family: var(--sans);
        font-size: 10.5pt;
        color: var(--text);
        background: var(--bg);
        line-height: 1.55;
      }

      .page {
        max-width: 820px;
        margin: 0 auto;
        padding: 2.5rem 2.5rem;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      /* ── Print controls (hidden in print) ── */
      .controls {
        display: flex;
        gap: 8px;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 16px;
        border-radius: 6px;
        border: 1px solid var(--border);
        font-family: var(--mono);
        font-size: 9pt;
        cursor: pointer;
        background: var(--bg);
        color: var(--text);
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
      }

      .btn--primary {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
      }
      .btn--primary:hover { background: #4648d8; text-decoration: none; }
      .btn:not(.btn--primary):hover { background: var(--surface); }

      /* ── Header ── */
      .resume-header { margin-bottom: 1.5rem; }

      .resume-name {
        font-size: 24pt;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--text);
        line-height: 1.1;
        margin-bottom: 4px;
      }

      .resume-title {
        font-size: 12pt;
        color: var(--muted);
        margin-bottom: 10px;
      }

      .resume-contacts {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        font-family: var(--mono);
        font-size: 8.5pt;
        color: var(--muted);
      }

      .resume-bio {
        margin-top: 12px;
        color: var(--muted);
        font-size: 10pt;
        max-width: 75ch;
        line-height: 1.65;
      }

      /* ── Section ── */
      .section-heading {
        font-family: var(--mono);
        font-size: 8pt;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--accent);
        border-bottom: 1px solid var(--border);
        padding-bottom: 5px;
        margin-bottom: 14px;
        margin-top: 26px;
      }

      /* ── Experience ── */
      .job { margin-bottom: 18px; }

      .job-top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 8px;
        margin-bottom: 2px;
        flex-wrap: wrap;
      }

      .job-company { font-size: 11pt; font-weight: 700; }

      .job-period {
        font-family: var(--mono);
        font-size: 8.5pt;
        color: var(--accent);
        white-space: nowrap;
      }

      .job-role { color: var(--muted); font-size: 10pt; margin-bottom: 5px; }

      .job-desc {
        font-size: 9.5pt;
        color: var(--muted);
        line-height: 1.65;
        margin-bottom: 6px;
        max-width: 80ch;
      }

      /* ── Tags ── */
      .tags { display: flex; flex-wrap: wrap; gap: 4px; }

      .tag {
        font-family: var(--mono);
        font-size: 7.5pt;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: 1px 6px;
        color: var(--muted);
      }

      /* ── Skills ── */
      .skills-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }

      .skill-cat-name {
        font-family: var(--mono);
        font-size: 8pt;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--accent);
        margin-bottom: 6px;
      }

      /* ── Projects ── */
      .project { margin-bottom: 14px; }
      .project-name { font-size: 11pt; font-weight: 700; }
      .project-desc { font-size: 9.5pt; color: var(--muted); margin: 4px 0 6px; line-height: 1.6; }

      /* ── Print ── */
      @page {
        size: A4;
        margin: 1.8cm 2cm;
      }

      @media print {
        body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .controls { display: none !important; }
        .page { padding: 0; max-width: 100%; }
        .job, .project { break-inside: avoid; }
        .section-heading { margin-top: 18px; }
        a { color: inherit; }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <!-- Controls -->
      <div class="controls">
        <a class="btn" href="/">← Portfolio</a>
        <button class="btn btn--primary" onclick="window.print()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/>
            <path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/>
          </svg>
          Save as PDF
        </button>
      </div>

      <!-- Header -->
      <header class="resume-header">
        <h1 class="resume-name">{social.nameEn}</h1>
        <p class="resume-title">{social.title}</p>
        <div class="resume-contacts">
          <a href={`mailto:${social.email}`}>{social.email}</a>
          {social.links.map(l => (
            <a href={l.url} target="_blank" rel="noopener noreferrer">{l.label}: {l.url.replace('https://', '')}</a>
          ))}
        </div>
        <p class="resume-bio">{social.bio}</p>
      </header>

      <!-- Experience -->
      <h2 class="section-heading">Experience</h2>
      {experience.map(e => (
        <div class="job">
          <div class="job-top">
            <span class="job-company">{e.data.company}</span>
            <span class="job-period">{e.data.startDate} — {e.data.current ? 'Present' : e.data.endDate}</span>
          </div>
          <p class="job-role">{e.data.positionEn} · {e.data.industry}</p>
          <p class="job-desc">{e.body}</p>
          <div class="tags">
            {e.data.technologies.map(tech => <span class="tag">{tech}</span>)}
          </div>
        </div>
      ))}

      <!-- Skills -->
      <h2 class="section-heading">Skills</h2>
      <div class="skills-grid">
        {skills.categories.map(cat => (
          <div class="skill-cat">
            <p class="skill-cat-name">{cat.name}</p>
            <div class="tags">
              {cat.items.map(item => <span class="tag">{item}</span>)}
            </div>
          </div>
        ))}
      </div>

      <!-- Projects -->
      <h2 class="section-heading">Open Source</h2>
      {projects.map(p => (
        <div class="project">
          <p class="project-name">
            {p.data.githubUrl
              ? <a href={p.data.githubUrl} target="_blank" rel="noopener noreferrer">{p.data.title}</a>
              : p.data.title}
          </p>
          <p class="project-desc">{p.data.description}</p>
          <div class="tags">
            {p.data.technologies.map(tech => <span class="tag">{tech}</span>)}
          </div>
        </div>
      ))}
    </div>

    <script>
      // Auto-print when opened with ?print=1
      const params = new URLSearchParams(window.location.search);
      if (params.get('print') === '1') {
        window.addEventListener('load', () => {
          setTimeout(() => window.print(), 300);
        });
      }
    </script>
  </body>
</html>
